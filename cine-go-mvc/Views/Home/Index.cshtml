@model List<Pelicula>
@{
    ViewData["Title"] = "Home Page";
    var paginaActual = ViewBag.PaginaActual ?? 1;
    var totalPaginas = ViewBag.TotalPaginas ?? 1;
    var totalPeliculas = ViewBag.TotalPeliculas ?? 0;
    var busqueda = ViewBag.TxtBusqueda ?? "";
    var generoId = ViewBag.GeneroId ?? 0;
}

<main class="flex-grow-1">
    <div class="container py-4">
        @* panel de filtros *@
        <form method="get">
            <div class="row g-3 mb-4 align-items-center">
                <div class="col-lg-6">
                    <div class="input-group">
                        <button type="submit" class="input-group-text">Buscar</button>
                        <input name="txtBusqueda" value="@busqueda" class="form-control form-control-lg" placeholder="Buscar películas..." type="text" />
                        <input type="hidden" name="origenPagina" value="@paginaActual" /> @* Guarda la página de origen para poder volver exactamente a ella *@
                        @if (!string.IsNullOrEmpty(busqueda)) @* Si hay texto en la búsqueda, muestra el btn de reset que retorna a la página origen *@
                        {
                            <a asp-action="Index" class="btn btn-outline-secondary ms-2" asp-route-pagina="@ViewBag.OrigenPagina" asp-route-txtBusqueda="" asp-route-generoId="@generoId">Resetear</a>
                        }
                    </div>
                </div>
                <div class="col-lg-6 d-flex flex-wrap gap-2 justify-content-lg-end">
                    <div class="dropdown">
                        <select name="generoId" asp-items="@ViewBag.Generos" class="form-select form-select-lg btn-outline-secondary"
                                onchange="this.form.submit()"></select>
                    </div>
                    <div class="btn-group" role="group">
                        <button class="btn btn-primary" type="button"><span class="material-symbols-outlined align-middle">grid_view</span></button>
                        <button class="btn btn-outline-secondary" type="button"><span class="material-symbols-outlined align-middle">view_list</span></button>
                    </div>
                </div>
            </div>
        </form>

        @* listado *@
        <div class="row row-cols-2 row-cols-sm-3 row-cols-md-4 g-4">
            @foreach (var pelicula in Model)
            {
                <div class="col">
                    <a asp-action="Details" asp-route-id="@pelicula.Id" class="text-decoration-none text-reset">
                        <div class="card h-100 border-0 shadow-sm">
                            <div class="position-relative">
                                <img alt="@pelicula.Titulo" class="card-img-top" src="@pelicula.PosterUrlPortada" />
                            </div>
                            <div class="card-body p-2">
                                <h5 class="card-title fs-6 fw-semibold mb-1">@pelicula.Titulo</h5>
                            </div>
                        </div>
                    </a>
                </div>
            }
        </div>
        
        <!-- Paginación -->
        @if (totalPaginas > 1)
        {
            <div class="row mt-4">
                <div class="col-12">
                    <nav aria-label="Navegación de páginas">
                        <ul class="pagination justify-content-center">
                            <!-- Botón Anterior -->
                            <li class="page-item @(paginaActual == 1 ? "disabled" : "")">
                                <a asp-action="Index" class="page-link" asp-route-pagina="@(paginaActual - 1)" asp-route-txtBusqueda="@busqueda" asp-route-generoId="@generoId" asp-route-origenPagina="@ViewBag.OrigenPagina">Anterior</a>
                            </li>

                            <!-- Números de página -->
                            @for (int i = 1; i <= totalPaginas; i++)
                            {
                                <li class="page-item @(i == paginaActual ? "active" : "")">
                                    <a asp-action="Index" asp-route-pagina="@i" class="page-link" asp-route-txtBusqueda="@busqueda" asp-route-generoId="@generoId" asp-route-origenPagina="@ViewBag.OrigenPagina">@i</a>
                                </li>
                            }

                            <!-- Botón Siguiente -->
                            <li class="page-item @(paginaActual == totalPaginas ? "disabled" : "")">
                                <a asp-action="Index" class="page-link" asp-route-pagina="@(paginaActual + 1)" asp-route-txtBusqueda="@busqueda" asp-route-generoId="@generoId" asp-route-origenPagina="@ViewBag.OrigenPagina">Siguiente</a>
                            </li>
                        </ul>
                    </nav>
                </div>
            </div>
        }
    </div>
</main>