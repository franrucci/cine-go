@using Microsoft.AspNetCore.Identity
@inject SignInManager<Usuario> SignInManager
@inject UserManager<Usuario> UserManager
@model Pelicula

@{
    ViewData["Title"] = "Detalles de la Película";
    int horas = Model.MinutosDuracion / 60;
    int minutos = Model.MinutosDuracion % 60;
    int anio = Model.FechaLanzamiento.Year;

}



<main class="container my-4">
    <div class="row g-4 g-lg-5">
        <div class="col-lg-4">
            <img alt="@Model.Titulo" class="img-fluid rounded-3 shadow-lg" src="@Model.PosterUrlPortada" />
        </div>
        <div class="col-lg-8">
            <h1 class="display-5 fw-bold">@Model.Titulo</h1>
            <p class="text-muted">@Model.Genero.Descripcion | @horas h @minutos m | @anio</p>
            <p class="lead">@Model.Sinopsis</p>
            <div class="card bg-light border p-4 my-4">
                <div class="row align-items-center">


                    @* Estrellas *@
                    <div class="col-sm-4 text-center text-sm-start">
                        <p class="display-2 fw-bolder text-dark mb-0">@ViewBag.Promedio</p>
                        <div class="star-rating" style="font-size:24px; line-height:1;">
                            @{ 
                                // Renderiza 5 contenedores de estrella cada uno con un ancho de relleno proporcional
                                // Usam ViewBag.Average (0..5) para calcular el porcentaje de llenado
                                double avg = (double)ViewBag.Average; // valor entre 0 y 5
                                for (int i = 1; i <= 5; i++)
                                {
                                    double starFill = Math.Clamp((avg - (i - 1)) * 100.0, 0.0, 100.0);
                                    <text>
                                        <span class="star-wrapper" style="display:inline-block; position:relative; width:1.1em;">
                                            <span class="star-empty" style="position:relative; display:inline-block; color:#6c757d;">star_border</span>
                                            <span class="star-filled-overlay" style="position:absolute; left:0; top:0; overflow:hidden; width:@starFill% ; color:#ffc107;">
                                                star
                                            </span>
                                        </span>
                                    </text>
                                }
                            }
                        </div>
                        <p class="text-muted mb-0">@ViewBag.TotalReviews reviews</p>
                    </div>
                    <div class="col-sm-8 mt-3 mt-sm-0">
                        <div class="row align-items-center gx-2 gy-1">
                            @for (int rating = 5; rating >= 1; rating--)
                            {
                                var counts = (int[])ViewBag.RatingCounts;
                                var percentages = (int[])ViewBag.RatingPercentages;
                                <div class="col-1 text-end text-dark fw-medium">@rating</div>
                                <div class="col-9">
                                    <div class="progress" style="height: 8px;">
                                        <div aria-valuemax="100" aria-valuemin="0" aria-valuenow="@percentages[rating]" class="progress-bar" role="progressbar" style="width: @percentages[rating]%"></div>
                                    </div>
                                </div>
                                <div class="col-2 text-muted text-end">@percentages[rating]%</div>
                            }
                        </div>
                    </div>
                </div>
            </div>


            @* Botones de acción *@
            <div class="d-grid gap-3 d-sm-flex my-4">
                <button class="btn btn-primary btn-lg d-flex align-items-center justify-content-center gap-2" type="button">
                    <span class="material-symbols-outlined">auto_awesome</span>
                    <span>Generar Resumen de Review</span>
                </button>
                <button class="btn btn-secondary btn-lg d-flex align-items-center justify-content-center gap-2" type="button">
                    <span class="material-symbols-outlined">movie</span>
                    <span>Películas Similares</span>
                </button>
                <button @(ViewBag.UserReview ? "disabled" : "") class="btn btn-secondary btn-lg d-flex align-items-center justify-content-center gap-2"
                    type="button" data-bs-toggle="modal" data-bs-target="#createReviewModal">
                    <span class="material-symbols-outlined">add_notes</span>
                    <span>Crear Reseña</span>
                </button>
            </div>


            <!-- Mostrar mensajes de éxito o error -->
            @if (TempData["ReviewExiste"] != null)
            {
                <div class="alert alert-danger alert-dismissible fade show" role="alert">
                    @TempData["ReviewExiste"]
                    <button type="button" class="btn-close" data-bs-dismiss="alert"></button>
                </div>
            }


            @* Reseñas *@
            <div class="mt-5">
                <h2 class="h3 fw-bold mb-4">Reviews</h2>
                <div class="list-group">

                    @foreach (var item in Model.ListaReviews)
                    {
                        <div class="list-group-item bg-dark text-light border-secondary review-card p-4 mb-3">
        
                            <div class="d-flex align-items-center mb-3">
                                <img alt="@item.Usuario.Nombre" class="rounded-circle me-3" height="40"
                                     src="@(string.IsNullOrEmpty(item.Usuario.ImagenUrlPerfil) ? "/images/default-avatar.png" : item.Usuario.ImagenUrlPerfil)"
                                     onerror="this.src='/images/default-avatar.png'" width="40" />
                                <div>
                                    <h5 class="mb-0 text-light">@string.Concat(item.Usuario.Nombre, " ", item.Usuario.Apellido)</h5>
                                    <small class="">@item.FechaReview.ToShortDateString()</small>
                                </div>
                            </div>

                            <div class="mb-2">
                                @for (int i = 1; i <= 5; i++)
                                {
                                    if (i <= item.Rating)
                                    {
                                        <span class="material-symbols-outlined star-filled">star</span>
                                    }
                                    else
                                    {
                                        <span class="material-symbols-outlined star-empty">grade</span>
                                    }
                                }
                            </div>

                            <p class="mb-3">@item.Comentario</p>

                            @if (SignInManager.IsSignedIn(User))
                            {
                                if (UserManager.IsInRoleAsync(await UserManager.GetUserAsync(User), "Admin").Result)
                                {
                                    <a asp-controller="Review" asp-action="Edit" asp-route-id="@item.Id" class="btn btn-sm btn-warning me-2 d-inline-flex align-items-center gap-1">
                                        <span class="material-symbols-outlined">edit</span>
                                        Editar
                                    </a>
                                }
                            }
                        </div>
                    }
                </div>
            </div>
        </div>
    </div>
</main>


@{
    var reviewViewModel = new ReviewCreateViewModel
    {
        PeliculaId = Model.Id,
        PeliculaTitulo = Model.Titulo
    };
}

<partial name="~/Views/Review/_CreateReview.cshtml" model="reviewViewModel" />

<style>
    .star-filled {
        color: #ffc107;
    }

    .star-empty {
        color: #6c757d;
    }
    /* Estilos para el relleno parcial de estrellas */
    .star-wrapper .star-filled-overlay {
        pointer-events: none;
    }
    /* Forzar icon font display: use material symbols font classes if available */
    .star-wrapper span {
        font-variation-settings: normal;
        font-family: 'Material Symbols Outlined', 'Material Icons', sans-serif;
    }
</style>