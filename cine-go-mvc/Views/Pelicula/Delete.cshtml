@model cine_go_mvc.Models.Pelicula

@{
    ViewData["Title"] = "Eliminar Película";
}

<div class="container mt-5">
    <div class="row justify-content-center">
        <div class="col-lg-7">

            <div class="card shadow-lg border-0 rounded-4 overflow-hidden">

                <!-- Header -->
                <div class="card-header bg-danger text-white">
                    <h4 class="mb-0 text-center">⚠️ Eliminar Película</h4>
                </div>

                <div class="card-body p-4">

                    <!-- Alerta -->
                    <div class="alert alert-warning text-center">
                        <strong>¿Estás seguro?</strong><br />
                        Esta acción no se puede deshacer.
                    </div>

                    <div class="row g-3 align-items-center">

                        <!-- Poster -->
                        <div class="col-md-4 text-center">
                            <img src="@Model.PosterUrlPortada"
                                 class="img-fluid rounded shadow-sm"
                                 alt="Poster"
                                 style="max-height: 250px; object-fit: cover;">
                        </div>

                        <!-- Info -->
                        <div class="col-md-8">

                            <h5 class="fw-bold mb-3">
                                🎬 @Model.Titulo
                            </h5>

                            <p class="text-muted small mb-3">
                                @Model.Sinopsis
                            </p>

                            <div class="mb-2">
                                <strong>📅 Lanzamiento:</strong>
                                @Model.FechaLanzamiento.ToShortDateString()
                            </div>

                            <div class="mb-2">
                                <strong>⏱ Duración:</strong>
                                @Model.MinutosDuracion min
                            </div>

                            <div class="mb-2">
                                <strong>🎭 Género:</strong>
                                @Model.Genero?.Descripcion
                            </div>

                            <div class="mb-2">
                                <strong>📺 Plataforma:</strong>
                                @Model.Plataforma?.Nombre
                            </div>

                        </div>
                    </div>

                    <!-- Botones -->
                    <form asp-action="Delete" class="mt-4">
                        <input type="hidden" asp-for="Id" />

                        <div class="d-flex justify-content-between">
                            <a asp-action="Index" class="btn btn-outline-secondary">
                                ← Cancelar
                            </a>

                            <button type="submit" class="btn btn-danger px-4">
                                Eliminar
                            </button>
                        </div>
                    </form>

                </div>
            </div>

        </div>
    </div>
</div>