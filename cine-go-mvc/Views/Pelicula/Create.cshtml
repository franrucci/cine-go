@model cine_go_mvc.Models.Pelicula

@{
    ViewData["Title"] = "Crear Película";
}

<h1 class="text-center fw-bold text-uppercase border-bottom pb-2 mb-4">
    Nueva Película
</h1>

<div class="row justify-content-center">
    <div class="col-lg-8">

        <div class="card shadow-sm rounded-4">
            <div class="card-body p-4">

                <form asp-action="Create" class="row g-3">

                    <div asp-validation-summary="ModelOnly" class="text-danger"></div>

                    <div class="col-12">
                        <label asp-for="Titulo" class="form-label fw-semibold"></label>
                        <input asp-for="Titulo" class="form-control" placeholder="Ej: Inception" />
                        <span asp-validation-for="Titulo" class="text-danger"></span>
                    </div>

                    <div class="col-12">
                        <label asp-for="Sinopsis" class="form-label fw-semibold"></label>
                        <textarea asp-for="Sinopsis" class="form-control" rows="3"></textarea>
                        <span asp-validation-for="Sinopsis" class="text-danger"></span>
                    </div>

                    <div class="col-md-6">
                        <label asp-for="FechaLanzamiento" class="form-label fw-semibold"></label>
                        <input asp-for="FechaLanzamiento" type="date" class="form-control" />
                        <span asp-validation-for="FechaLanzamiento" class="text-danger"></span>
                    </div>

                    <div class="col-md-6">
                        <label asp-for="MinutosDuracion" class="form-label fw-semibold"></label>
                        <input asp-for="MinutosDuracion" class="form-control" placeholder="120" />
                        <span asp-validation-for="MinutosDuracion" class="text-danger"></span>
                    </div>

                    <div class="col-12">
                        <label asp-for="PosterUrlPortada" class="form-label fw-semibold"></label>
                        <input asp-for="PosterUrlPortada" class="form-control" placeholder="URL de la imagen" />
                        <span asp-validation-for="PosterUrlPortada" class="text-danger"></span>
                    </div>

                    <div class="col-md-6">
                        <label class="form-label fw-semibold">Género</label>
                        <select asp-for="GeneroId" class="form-select" asp-items="ViewBag.GeneroId"></select>
                    </div>

                    <div class="col-md-6">
                        <label class="form-label fw-semibold">Plataforma</label>
                        <select asp-for="PlataformaId" class="form-select" asp-items="ViewBag.PlataformaId"></select>
                    </div>

                    <div class="col-12 d-flex justify-content-between mt-3">
                        <a asp-action="Index" class="btn btn-outline-secondary">
                            Volver
                        </a>

                        <button type="submit" class="btn btn-primary px-4">
                            Guardar
                        </button>
                    </div>

                </form>

            </div>
        </div>

    </div>
</div>

@section Scripts {
    @{
        await Html.RenderPartialAsync("_ValidationScriptsPartial");
    }
}