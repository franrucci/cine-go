@model IEnumerable<cine_go_mvc.Models.Genero>

@section Styles {
    <link rel="stylesheet" href="~/css/genero.css" />
}

@{
    ViewData["Title"] = "Géneros";
}

<h1 class="text-center fw-bold text-uppercase border-bottom pb-2 mb-4">
    Géneros
</h1>

<p>
    <a asp-action="Create" class="btn btn-success">Agregar Nuevo Género</a>
</p>

<link rel="stylesheet" href="https://cdn.datatables.net/1.13.6/css/jquery.dataTables.min.css" />

<div class="table-responsive">
    <table id="generosTable" class="table table-striped table-bordered text-center align-middle">
        <thead class="table-active">
            <tr>
                <th>Descripción</th>
                <th></th>
            </tr>
        </thead>
        <tbody>
            @foreach (var item in Model)
            {
                <tr>
                    <td>@item.Descripcion</td>

                    <td class="acciones-col">
                        <div class="acciones-container">
                            <a asp-action="Edit" asp-route-id="@item.Id" class="btn btn-sm btn-primary">Modificar</a>
                            <a asp-action="Delete" asp-route-id="@item.Id" class="btn btn-sm btn-danger">Eliminar</a>
                        </div>
                    </td>
                </tr>
            }
        </tbody>
    </table>
</div>

@section Scripts {
    <script src="https://code.jquery.com/jquery-3.7.1.min.js"></script>
    <script src="https://cdn.datatables.net/1.13.6/js/jquery.dataTables.min.js"></script>

    <script>
        $(document).ready(function () {
        $('#generosTable').DataTable({
        language: {
        url: "//cdn.datatables.net/plug-ins/1.13.6/i18n/es-ES.json"
        },
        columnDefs: [
        { targets: [1], orderable: false }
        ],
        order: [[0, 'asc']]
        });
        });
    </script>
}