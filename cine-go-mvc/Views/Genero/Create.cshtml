@model cine_go_mvc.Models.Genero

@{
    ViewData["Title"] = "Crear Género";
}

<h1 class="text-center fw-bold text-uppercase border-bottom pb-2 mb-4">
    Nuevo Género
</h1>

<div class="row justify-content-center">
    <div class="col-lg-5">

        <div class="card shadow-sm rounded-4">
            <div class="card-body p-4">

                <form asp-action="Create" class="row g-3">

                    <div asp-validation-summary="ModelOnly" class="text-danger"></div>

                    <div class="col-12">
                        <label asp-for="Descripcion" class="form-label fw-semibold"></label>
                        <input asp-for="Descripcion" class="form-control" placeholder="Ej: Acción, Drama..." />
                        <span asp-validation-for="Descripcion" class="text-danger"></span>
                    </div>

                    <div class="col-12 d-flex justify-content-between mt-3">
                        <a asp-action="Index" class="btn btn-outline-secondary">
                            Volver
                        </a>

                        <button type="submit" class="btn btn-primary px-4">
                            Guardar
                        </button>
                    </div>

                </form>

            </div>
        </div>

    </div>
</div>

@section Scripts {
    @{
        await Html.RenderPartialAsync("_ValidationScriptsPartial");
    }
}