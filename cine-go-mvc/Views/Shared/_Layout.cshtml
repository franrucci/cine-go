@using Microsoft.AspNetCore.Identity
@inject SignInManager<Usuario> SignInManager
@inject UserManager<Usuario> UserManager

<!DOCTYPE html>
<html lang="en" data-bs-theme="dark">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>CineGo</title>
    <script type="importmap"></script>
    <link rel="icon" type="image/png" href="~/cine_go.png" />
    <link rel="stylesheet" href="~/lib/bootstrap/dist/css/bootstrap.min.css" />
    <link rel="stylesheet" href="~/css/site.css" asp-append-version="true" />
    <link rel="stylesheet" href="~/cine_go_mvc.styles.css" asp-append-version="true" />
    <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.11.3/font/bootstrap-icons.min.css">

    <link href="https://fonts.googleapis.com/css2?family=Material+Symbols+Outlined" rel="stylesheet" />

    @RenderSection("Styles", required: false)
</head>
<body>
    <header>
        <nav class="navbar navbar-expand-sm navbar-toggleable-sm navbar-dark bg-dark border-bottom box-shadow fixed-top">
            <div class="container-fluid">
                <a class="navbar-brand" asp-area="" asp-controller="Home" asp-action="Index">
                    <a class="navbar-brand" asp-area="" asp-controller="Home" asp-action="Index">

                        <img src="~/cine_go.png"
                             alt="CineGo"
                             height="32"
                             class="me-2" />

                        <span class="fs-5 fw-bold">CineGo</span>

                    </a>
                </a>
                <button class="navbar-toggler" type="button" data-bs-toggle="collapse" data-bs-target=".navbar-collapse" aria-controls="navbarSupportedContent"
                        aria-expanded="false" aria-label="Toggle navigation">
                    <span class="navbar-toggler-icon"></span>
                </button>
                <div class="navbar-collapse collapse d-sm-inline-flex justify-content-between">
                    <ul class="navbar-nav flex-grow-1">
                        <li class="nav-item">
                            <a class="nav-link" asp-area="" asp-controller="Home" asp-action="Index">Home</a>
                        </li>

                        @if (SignInManager.IsSignedIn(User))
                        {
                            if (UserManager.IsInRoleAsync(await UserManager.GetUserAsync(User), "Admin").Result)
                            {
                                <li class="nav-item">
                                    <a class="nav-link" asp-area="" asp-controller="Genero" asp-action="Index">Géneros</a>
                                </li>
                                <li class="nav-item">
                                    <a class="nav-link" asp-area="" asp-controller="Plataforma" asp-action="Index">Plataformas</a>
                                </li>
                                <li class="nav-item">
                                    <a class="nav-link" asp-area="" asp-controller="Pelicula" asp-action="Index">Películas</a>
                                </li>
                            }
                            else
                            {
                                <li class="nav-item">
                                    <a class="nav-link" asp-area="" asp-controller="Review" asp-action="Index">Mis Reseñas</a>
                                </li>
                            }
                        }

                    </ul>
                </div>

                <ul class="navbar-nav flex-grow">
                    @if (SignInManager.IsSignedIn(User))
                    {
                        <li class="nav-item">
                            <a class="btn btn-primary" asp-area="" asp-controller="Usuario" asp-action="MiPerfil">Mi Perfil</a>
                        </li>
                        <li class="nav-item">
                            <form asp-area="" asp-controller="Usuario" asp-action="Logout" method="post" class="d-inline">
                                <button type="submit" class="btn btn-link nav-link text-white">Cerrar sesión</button>
                            </form>
                        </li>
                    }
                    else
                    {
                        <li class="nav-item">
                            <a class="nav-link text-white" asp-area="" asp-controller="Usuario" asp-action="Login">Iniciar sesión</a>
                        </li>
                        <li class="nav-item">
                            <a class="nav-link text-white" asp-area="" asp-controller="Usuario" asp-action="Registro">Registrarse</a>
                        </li>
                    }
                </ul>
                                                                                                    
            </div>
        </nav>
    </header>
    <div class="container">
        <main role="main" class="pb-3">
            @RenderBody()
        </main>
    </div>

    <footer class="footer mt-auto py-4 bg-dark text-light border-top">
        <div class="container">

            <div class="row align-items-center">

                <!-- Branding -->
                <div class="col-md-4 mb-3 mb-md-0">
                    <h5 class="fw-bold mb-1">CineGo</h5>
                    <small class="text-light opacity-75">
                        Plataforma de películas con recomendaciones e IA
                    </small>
                </div>

                <!-- Contacto -->
                <div class="col-md-4 mb-3 mb-md-0 text-md-center">
                    <small class="text-light opacity-75">
                        <i class="bi bi-envelope-fill me-1"></i> franrucci01@gmail.com
                    </small>
                </div>

                <!-- Autor -->
                <div class="col-md-4 text-md-end">
                    <small class="text-light opacity-75">
                        Desarrollado por <strong>Francisco Rucci</strong>
                    </small>
                </div>

            </div>

            <hr class="border-secondary my-3" />

            <div class="text-center small text-light opacity-75">
                © 2026 CineGo. Todos los derechos reservados.
            </div>

        </div>
    </footer>
    <script src="~/lib/jquery/dist/jquery.min.js"></script>
    <script src="~/lib/bootstrap/dist/js/bootstrap.bundle.min.js"></script>
    <script src="~/js/site.js" asp-append-version="true"></script>
    @await RenderSectionAsync("Scripts", required: false)
</body>
</html>
