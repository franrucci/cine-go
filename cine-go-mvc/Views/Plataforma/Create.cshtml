@model cine_go_mvc.Models.Plataforma

@{
    ViewData["Title"] = "Crear Plataforma";
}

<h1 class="text-center fw-bold text-uppercase border-bottom pb-2 mb-4">
    Nueva Plataforma
</h1>

<div class="row justify-content-center">
    <div class="col-lg-6">

        <div class="card shadow-sm rounded-4">
            <div class="card-body p-4">

                <form asp-action="Create" class="row g-3">

                    <div asp-validation-summary="ModelOnly" class="text-danger"></div>

                    <div class="col-12">
                        <label asp-for="Nombre" class="form-label fw-semibold"></label>
                        <input asp-for="Nombre" class="form-control" placeholder="Ej: Netflix" />
                        <span asp-validation-for="Nombre" class="text-danger"></span>
                    </div>

                    <div class="col-12">
                        <label asp-for="Url" class="form-label fw-semibold"></label>
                        <input asp-for="Url" class="form-control" placeholder="https://..." />
                        <span asp-validation-for="Url" class="text-danger"></span>
                    </div>

                    <div class="col-12">
                        <label asp-for="LogoUrl" class="form-label fw-semibold"></label>
                        <input asp-for="LogoUrl" class="form-control" placeholder="URL del logo" />
                        <span asp-validation-for="LogoUrl" class="text-danger"></span>
                    </div>

                    <div class="col-12 d-flex justify-content-between mt-3">
                        <a asp-action="Index" class="btn btn-outline-secondary">
                            Volver
                        </a>

                        <button type="submit" class="btn btn-primary px-4">
                            Guardar
                        </button>
                    </div>

                </form>

            </div>
        </div>

    </div>
</div>

@section Scripts {
    @{
        await Html.RenderPartialAsync("_ValidationScriptsPartial");
    }
}