@model cine_go_mvc.Models.Plataforma

@{
    ViewData["Title"] = "Editar Plataforma";
}

<div class="container mt-5">
    <div class="row justify-content-center">
        <div class="col-lg-6">

            <div class="card shadow-lg border-0 rounded-4">

                <div class="card-header bg-dark text-white">
                    <h4 class="mb-0">🖥️ Editar Plataforma</h4>
                </div>

                <div class="card-body p-4">

                    <form asp-action="Edit">

                        <div asp-validation-summary="ModelOnly" class="alert alert-danger"></div>

                        <input type="hidden" asp-for="Id" />

                        <div class="mb-3">
                            <label asp-for="Nombre" class="form-label fw-semibold"></label>
                            <input asp-for="Nombre" class="form-control form-control-lg" placeholder="Ej: Netflix" />
                            <span asp-validation-for="Nombre" class="text-danger small"></span>
                        </div>

                        <div class="mb-3">
                            <label asp-for="Url" class="form-label fw-semibold"></label>
                            <input asp-for="Url" class="form-control" placeholder="https://..." />
                            <span asp-validation-for="Url" class="text-danger small"></span>
                        </div>

                        <div class="mb-3">
                            <label asp-for="LogoUrl" class="form-label fw-semibold"></label>
                            <input asp-for="LogoUrl" class="form-control" placeholder="URL del logo" />
                            <span asp-validation-for="LogoUrl" class="text-danger small"></span>
                        </div>

                        <div class="d-flex justify-content-between mt-4">

                            <a asp-action="Index" class="btn btn-outline-secondary">
                                ← Volver
                            </a>

                            <button type="submit" class="btn btn-primary px-4">
                                Guardar
                            </button>

                        </div>

                    </form>

                </div>
            </div>

        </div>
    </div>
</div>

@section Scripts {
    @{
        await Html.RenderPartialAsync("_ValidationScriptsPartial");
    }
}